---
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for post in site.posts %}{% unless post.draft == true %}
  <url><loc>{{ site.url }}{{ post.url }}</loc><lastmod>{{ post.date | date_to_xmlschema }}</lastmod></url>
{% endunless %}{% endfor %}
{% for item in site.wiki %}
  <url><loc>{{ site.url }}{{ item.url }}</loc></url>
{% endfor %}
{% for item in site.library %}
  <url><loc>{{ site.url }}{{ item.url }}</loc></url>
{% endfor %}
{% for chain in site.blogchains %}
  <url><loc>{{ site.url }}{{ chain.url }}</loc></url>
{% endfor %}
{% for page in site.html_pages %}{% if page.url != "/404.html" %}
  <url><loc>{{ site.url }}{{ page.url }}</loc></url>
{% endif %}{% endfor %}
</urlset>
